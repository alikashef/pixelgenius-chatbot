{
	email {$CADDY_EMAIL}
}

(app_routes) {
	encode gzip zstd

	header {
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
	}

	handle /api/* {
		reverse_proxy backend:8000
	}

	handle /health {
		reverse_proxy backend:8000
	}

	handle /uploads/* {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$APP_DOMAIN} {
	import app_routes
}

http://:80 {
	import app_routes
}
